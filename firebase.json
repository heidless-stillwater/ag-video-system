{
    "hosting": [
        {
            "site": "videosystem-v0",
            "source": "deploy-static",
            "ignore": [
                "firebase.json",
                "**/.*",
                "node_modules/**"
            ],
            "rewrites": [
                {
                    "source": "**",
                    "run": {
                        "serviceId": "videosystem-v0",
                        "region": "us-central1"
                    }
                }
            ]
        }
    ],
    "firestore": [
        {
            "database": "autovideo-db-0",
            "rules": "firestore.rules",
            "indexes": "firestore.indexes.json"
        },
        {
            "database": "(default)",
            "rules": "firestore.rules",
            "indexes": "firestore.indexes.json"
        }
    ]
}