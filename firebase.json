{
    "hosting": [
        {
            "target": "autovideo",
            "source": ".",
            "ignore": [
                "firebase.json",
                "**/.*",
                "node_modules/**",
                "public/renders/**",
                "public/audio/**",
                "tmp/**",
                "node_modules/ffprobe-static/bin/darwin/**",
                "node_modules/ffprobe-static/bin/win32/**",
                "node_modules/ffprobe-static/bin/linux/ia32/**"
            ],
            "rewrites": [
                {
                    "source": "**",
                    "function": "ssrautovideov0dev"
                }
            ]
        }
    ]
}