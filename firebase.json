{
    "hosting": [
        {
            "site": "videosystem-v0",
            "source": ".",
            "ignore": [
                "firebase.json",
                "**/.*",
                "node_modules/**"
            ]
        }
    ],
    "firestore": [
        {
            "database": "autovideo-db-0",
